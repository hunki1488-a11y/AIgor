@@ -0,0 +1,21 @@
+"""prepare_creative_brief MCP tool."""
+
+from mcp.server.fastmcp import FastMCP
+
+from vos_studio_mcp.schemas.brief import BriefIntakeInput, BriefIntakeResponse
+from vos_studio_mcp.services.brief_service import (
+    prepare_creative_brief as _prepare_creative_brief,
+)
+from vos_studio_mcp.tools._instrumentation import instrument
+
+
+def register_prepare_creative_brief_tools(mcp: FastMCP) -> None:
+    @mcp.tool()
+    @instrument
+    async def prepare_creative_brief(data: BriefIntakeInput) -> BriefIntakeResponse:
+        """Normalize messy client input into a compact sprint-ready creative brief.
+
+        Produces strategy, asset, approval, and missing-information sections
+        without external provider calls or paid side effects.
+        """
+        return await _prepare_creative_brief(data)
