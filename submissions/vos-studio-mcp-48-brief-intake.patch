index 0000000..545b361
--- /dev/null
+++ b/src/vos_studio_mcp/services/brief_service.py
@@ -0,0 +1,145 @@
+"""Brief intake service.
+
+Pure deterministic composition: no provider execution and no paid side effects.
+"""
+
+from vos_studio_mcp.auth.guards import assert_owns_client
+from vos_studio_mcp.schemas.brief import BriefIntakeInput, BriefIntakeResponse, BriefQuestion
+from vos_studio_mcp.services.rate_limiter import check_rate_limit
+
+
+def _sentences(text: str, limit: int) -> list[str]:
+    normalized = " ".join(text.replace("\n", " ").split())
+    if not normalized:
+        return []
+    parts = [p.strip(" .") for p in normalized.replace("?", ".").replace("!", ".").split(".")]
+    return [p for p in parts if p][:limit]
+
+
+def _contains_any(text: str, needles: tuple[str, ...]) -> bool:
+    lowered = text.lower()
+    return any(needle in lowered for needle in needles)
+
+
+def _build_missing_information(data: BriefIntakeInput) -> list[BriefQuestion]:
+    questions: list[BriefQuestion] = []
+    brief_text = data.raw_brief.lower()
+    if not _contains_any(brief_text, ("goal", "objective", "kpi", "conversion", "awareness")):
+        questions.append(
+            BriefQuestion(
+                topic="objective",
+                question="Which primary KPI should this creative sprint optimize for?",
+                reason="The raw brief does not name a measurable objective.",
+            )
+        )
+    if not _contains_any(brief_text, ("budget", "deadline", "launch", "timing", "date")):
+        questions.append(
+            BriefQuestion(
+                topic="timing_budget",
+                question="What launch window and budget ceiling should the sprint assume?",
+                reason="Sprint planning needs delivery and spend constraints before execution.",
+            )
+        )
+    if not data.claims and not data.compliance_notes:
+        questions.append(
+            BriefQuestion(
+                topic="claims_compliance",
+                question="Which claims are approved, restricted, or legally sensitive?",
+                reason="Creative outputs need claim boundaries before provider or manual production.",
+            )
+        )
+    return questions
+
+
+def _extract_pain_points(data: BriefIntakeInput) -> list[str]:
+    candidates = _sentences(data.raw_brief, 4)
+    if candidates:
+        return candidates[:3]
+    return [
+        f"{data.target_audience} needs a clearer reason to care about {data.product_service_description}."
+    ]
+
+
+def _build_angles(data: BriefIntakeInput, pain_points: list[str]) -> list[str]:
+    voice = data.brand_voice or "brand-safe"
+    first_pain = pain_points[0] if pain_points else "the core customer problem"
+    return [
+        f"Pain-to-relief angle: show {first_pain} and resolve it with {data.product_service_description}.",
+        f"Proof-first angle: lead with the strongest approved claim for {data.channel_platform}.",
+        f"Objection-handling angle: address why {data.target_audience} may hesitate before buying.",
+        f"Voice-fit angle: express the promise in a {voice} tone without unsupported claims.",
+    ]
+
+
+async def prepare_creative_brief(data: BriefIntakeInput) -> BriefIntakeResponse:
+    """Turn messy client input into a compact sprint-ready creative plan."""
+    assert_owns_client(data.client_id)
+    await check_rate_limit("prepare_creative_brief", data.client_id)
+
+    pain_points = _extract_pain_points(data)
+    objections = [
+        "Unclear value versus current alternatives.",
+        "Low trust in claims unless proof is visible.",
+    ]
+    if data.forbidden_topics:
+        objections.append("Creative must avoid restricted topics and sensitive framing.")
+
+    required_assets = [
+        f"{data.channel_platform} primary video or static concept",
+        "Hook variants for first-frame testing",
+        "Proof/claim visual card",
+        "Approval notes for claims and restricted topics",
+    ]
+    provider_notes = [
+        "Manual dashboard mode is safest until the brief and claims are approved.",
+        "API providers should remain blocked until budget and human approval are explicit.",
+    ]
+    if data.forbidden_topics or data.compliance_notes:
+        provider_notes.append("Run compliance review before provider execution.")
+
+    creative_angles = _build_angles(data, pain_points)
+    missing_information = _build_missing_information(data)
+    campaign_objective = (
+        _sentences(data.raw_brief, 1)[0]
+        if _sentences(data.raw_brief, 1)
+        else f"Create a {data.channel_platform} campaign for {data.product_service_description}."
+    )
+
+    approval_checklist = [
+        "Confirm campaign objective and KPI.",
+        "Confirm approved claims and forbidden topics.",
+        "Confirm budget ceiling before any paid provider execution.",
+        "Confirm final target audience and channel format.",
+    ]
+
+    sprint_handoff: dict[str, object] = {
+        "client_id": data.client_id,
+        "product_name": data.product_service_description[:120],
+        "campaign_objective": campaign_objective,
+        "target_audience": data.target_audience,
+        "brief": data.raw_brief,
+        "mode": "dashboard_manual",
+        "creative_angles": creative_angles,
+        "missing_information_count": len(missing_information),
+    }
+
+    return BriefIntakeResponse(
+        status="ready",
+        campaign_objective=campaign_objective,
+        offer_and_promise=f"Position {data.product_service_description} for {data.target_audience}.",
+        target_persona=data.target_audience,
+        pain_points=pain_points,
+        objections=objections,
+        creative_angles=creative_angles,
+        required_assets=required_assets,
+        suggested_sprint_type="manual_dashboard_validation",
+        provider_suitability_notes=provider_notes,
+        approval_checklist=approval_checklist,
+        missing_information=missing_information,
+        sprint_handoff=sprint_handoff,
+        summary=(
+            f"Prepared compact brief for {data.channel_platform} with "
+            f"{len(creative_angles)} angles and {len(missing_information)} open question(s)."
+        ),
+        next_action="create_creative_sprint",
+    )
