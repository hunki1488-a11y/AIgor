+"""Creative brief intake schemas."""
+
+from pydantic import BaseModel, Field
+
+
+class BriefIntakeInput(BaseModel):
+    client_id: str = Field(..., description="Client that owns the brief.")
+    raw_brief: str = Field(..., min_length=1, description="Unstructured client brief text.")
+    product_service_description: str = Field(
+        ..., min_length=1, description="Product or service context."
+    )
+    target_audience: str = Field(..., min_length=1)
+    channel_platform: str = Field(..., min_length=1)
+    brand_voice: str | None = None
+    claims: list[str] = Field(default_factory=list)
+    forbidden_topics: list[str] = Field(default_factory=list)
+    compliance_notes: list[str] = Field(default_factory=list)
+
+
+class BriefQuestion(BaseModel):
+    topic: str
+    question: str
+    reason: str
+
+
+class BriefIntakeResponse(BaseModel):
+    status: str
+    campaign_objective: str
+    offer_and_promise: str
+    target_persona: str
+    pain_points: list[str]
+    objections: list[str]
+    creative_angles: list[str]
+    required_assets: list[str]
+    suggested_sprint_type: str
+    provider_suitability_notes: list[str]
+    approval_checklist: list[str]
+    missing_information: list[BriefQuestion]
+    sprint_handoff: dict[str, object]
+    summary: str
+    next_action: str
diff --git a/src/vos_studio_mcp/services/brief_service.py b/src/vos_studio_mcp/services/brief_service.py
