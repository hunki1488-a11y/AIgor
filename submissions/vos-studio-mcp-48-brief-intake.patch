+async def test_prepare_creative_brief_delegates_to_service() -> None:
+    from vos_studio_mcp.schemas.brief import BriefIntakeInput, BriefIntakeResponse
+    from vos_studio_mcp.tools.prepare_creative_brief import register_prepare_creative_brief_tools
+
+    mock_mcp, captured = _make_mock_mcp()
+    register_prepare_creative_brief_tools(mock_mcp)  # type: ignore[arg-type]
+
+    data = BriefIntakeInput(
+        client_id=_client_id(),
+        raw_brief="Need TikTok launch ideas for a skincare serum.",
+        product_service_description="Hydrating serum",
+        target_audience="Busy skincare buyers",
+        channel_platform="TikTok",
+    )
+    mock_resp = BriefIntakeResponse(
+        status="ready",
+        campaign_objective="Need TikTok launch ideas for a skincare serum",
+        offer_and_promise="Position Hydrating serum for Busy skincare buyers.",
+        target_persona="Busy skincare buyers",
+        pain_points=["Need TikTok launch ideas for a skincare serum"],
+        objections=["Unclear value versus current alternatives."],
+        creative_angles=["Proof-first angle"],
+        required_assets=["TikTok primary concept"],
+        suggested_sprint_type="manual_dashboard_validation",
+        provider_suitability_notes=["Manual dashboard mode is safest."],
+        approval_checklist=["Confirm claims."],
+        missing_information=[],
+        sprint_handoff={"client_id": _client_id()},
+        summary="Prepared compact brief.",
+        next_action="create_creative_sprint",
+    )
+
+    with patch(
+        "vos_studio_mcp.tools.prepare_creative_brief._prepare_creative_brief",
+        new=AsyncMock(return_value=mock_resp),
+    ) as mock_svc:
+        result = await captured["prepare_creative_brief"](data=data)
+
+    mock_svc.assert_awaited_once_with(data)
+    assert result is mock_resp
+
+
