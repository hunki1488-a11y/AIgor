+++ b/tests/services/test_brief_service.py
@@ -0,0 +1,69 @@
+"""Unit tests for brief_service.prepare_creative_brief."""
+
+from unittest.mock import AsyncMock, patch
+
+import pytest
+
+from vos_studio_mcp.schemas.brief import BriefIntakeInput
+from vos_studio_mcp.services.brief_service import prepare_creative_brief
+
+_MODULE = "vos_studio_mcp.services.brief_service"
+
+
+def _input(**overrides: object) -> BriefIntakeInput:
+    data: dict[str, object] = {
+        "client_id": "00000000-0000-0000-0000-000000000001",
+        "raw_brief": "Launch a TikTok campaign for a serum. Goal is trials from busy buyers.",
+        "product_service_description": "Hydrating serum",
+        "target_audience": "Busy skincare buyers",
+        "channel_platform": "TikTok",
+        "brand_voice": "clinical but warm",
+    }
+    data.update(overrides)
+    return BriefIntakeInput(**data)  # type: ignore[arg-type]
+
+
+@pytest.mark.asyncio
+async def test_prepare_creative_brief_returns_compact_handoff() -> None:
+    with (
+        patch(f"{_MODULE}.assert_owns_client"),
+        patch(f"{_MODULE}.check_rate_limit", new_callable=AsyncMock),
+    ):
+        result = await prepare_creative_brief(_input())
+
+    assert result.status == "ready"
+    assert result.next_action == "create_creative_sprint"
+    assert result.suggested_sprint_type == "manual_dashboard_validation"
+    assert len(result.creative_angles) == 4
+    assert result.sprint_handoff["mode"] == "dashboard_manual"
+    assert result.sprint_handoff["missing_information_count"] == len(result.missing_information)
+
+
+@pytest.mark.asyncio
+async def test_prepare_creative_brief_surfaces_missing_claims_and_budget() -> None:
+    with (
+        patch(f"{_MODULE}.assert_owns_client"),
+        patch(f"{_MODULE}.check_rate_limit", new_callable=AsyncMock),
+    ):
+        result = await prepare_creative_brief(
+            _input(raw_brief="Need some creative ideas.", claims=[], compliance_notes=[])
+        )
+
+    topics = {question.topic for question in result.missing_information}
+    assert "objective" in topics
+    assert "timing_budget" in topics
+    assert "claims_compliance" in topics
+
+
+@pytest.mark.asyncio
+async def test_prepare_creative_brief_respects_restricted_topics() -> None:
+    with (
+        patch(f"{_MODULE}.assert_owns_client"),
+        patch(f"{_MODULE}.check_rate_limit", new_callable=AsyncMock),
+    ):
+        result = await prepare_creative_brief(
+            _input(forbidden_topics=["medical diagnosis"], compliance_notes=["No cure claims."])
+        )
+
+    assert any("restricted topics" in objection for objection in result.objections)
+    assert any("compliance review" in note for note in result.provider_suitability_notes)
