@@ -0,0 +1,53 @@
+import importlib
+import os
+import subprocess
+import sys
+import types
+import unittest
+from unittest.mock import patch
+
+current_dir = os.path.dirname(os.path.abspath(__file__))
+aim_root = os.path.dirname(current_dir)
+sys.path.append(os.path.join(aim_root, "aim_core"))
+sys.modules.setdefault("requests", types.SimpleNamespace())
+sys.modules.setdefault("keyring", types.SimpleNamespace(get_password=lambda *_args, **_kwargs: None))
+reasoning_utils = importlib.import_module("reasoning_utils")
+
+
+class TestReasoningUtilsBackgroundCli(unittest.TestCase):
+    @patch("reasoning_utils.subprocess.run")
+    def test_oauth_cli_uses_isolated_home_and_headless_trust(self, mock_run):
+        mock_run.return_value = subprocess.CompletedProcess(
+            args=["gemini"],
+            returncode=0,
+            stdout='{"response": "OK"}',
+            stderr="",
+        )
+
+        result = reasoning_utils.execute_google(
+            "prompt",
+            "system",
+            "gemini-3.1-flash-lite-preview",
+            auth_type="OAuth",
+        )
+
+        self.assertEqual(result, "OK")
+
+        _, kwargs = mock_run.call_args
+        env = kwargs["env"]
+
+        self.assertEqual(env["AIM_INTERNAL_REASONING"], "1")
+        self.assertEqual(env["GEMINI_CLI_HOME"], reasoning_utils.BACKGROUND_CLI_HOME)
+        self.assertEqual(env["GEMINI_CLI_TRUST_WORKSPACE"], "true")
+        self.assertEqual(env["GEMINI_CLI_SURFACE"], "aim-background-reasoning")
+        self.assertEqual(
+            env["GEMINI_CLI_TRUSTED_FOLDERS_PATH"],
+            os.path.join(reasoning_utils.BACKGROUND_CLI_HOME, ".gemini", "trustedFolders.json"),
+        )
+        self.assertNotIn("GEMINI_CLI_TMP_DIR", env)
+        self.assertNotIn("GEMINI_CLI_DISABLE_CHECKPOINT", env)
+        self.assertEqual(kwargs["cwd"], os.path.join(reasoning_utils.AIM_ROOT, "memory-wiki"))
+
+
+if __name__ == "__main__":
+    unittest.main()
